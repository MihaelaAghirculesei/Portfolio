{
  "name": "angular-portofolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:angular-portofolio": "node dist/angular-portofolio/server/server.mjs",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.html\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"src/**/*.html\" --fix",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "ci:security": "npm audit --audit-level=moderate",
    "ci:quality": "npm run lint && ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "ci:build": "ng build --configuration=production",
    "ci:local": "npm outdated || node -e \"\" && npm run ci:security && npm run ci:quality && npm run ci:build",
    "build:purge": "ng build --configuration=production && npx purgecss --css \"dist/angular-portofolio/browser/**/*.css\" --content \"dist/angular-portofolio/browser/**/*.html\" \"dist/angular-portofolio/browser/**/*.js\" --output dist/angular-portofolio/browser/",
    "lighthouse": "lighthouse http://localhost:4200 --output html --output-path ./lighthouse-report.html --chrome-flags=\"--headless\"",
    "lighthouse:ssr": "lighthouse http://localhost:4000 --output html --output-path ./lighthouse-ssr-report.html --chrome-flags=\"--headless\"",
    "lighthouse:prod": "lighthouse https://aghirculesei.pages.dev --output html --output-path ./lighthouse-report.html --chrome-flags=\"--headless\""
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.11",
    "@angular/compiler": "^21.2.11",
    "@angular/core": "^21.2.11",
    "@angular/forms": "^21.2.11",
    "@angular/platform-browser": "^21.2.11",
    "@angular/platform-browser-dynamic": "^21.2.11",
    "@angular/platform-server": "^21.2.11",
    "@angular/router": "^21.2.11",
    "@angular/ssr": "^21.2.9",
    "@ngx-translate/core": "^17.0.0",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "tar": ">=7.5.11",
    "uuid": ">=14.0.0",
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^20.3.0",
    "@angular-eslint/eslint-plugin": "^20.3.0",
    "@angular-eslint/eslint-plugin-template": "^20.3.0",
    "@angular-eslint/schematics": "^20.3.0",
    "@angular-eslint/template-parser": "^20.3.0",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.11",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "angular-eslint": "^20.3.0",
    "eslint": "^9.37.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^60.8.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "purgecss": "^6.0.0",
    "sharp": "^0.34.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}